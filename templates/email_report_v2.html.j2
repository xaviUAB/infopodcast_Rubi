<!doctype html>
<html lang="ca">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Informe diari de Rubí v3</title>
</head>
<body style="margin:0;padding:24px;background:#eef2f7;font-family:Arial,Helvetica,sans-serif;color:#1f2937;">
  <table role="presentation" width="100%" cellspacing="0" cellpadding="0" style="width:100%;max-width:980px;margin:0 auto;background:#ffffff;border:1px solid #d9e2ec;border-radius:12px;overflow:hidden;">
    <tr>
      <td style="padding:28px 32px;background:#0f4c81;color:#ffffff;">
        <h1 style="margin:0 0 8px 0;font-size:28px;line-height:1.2;">Informe diari de Rubí · versió 3</h1>
        <p style="margin:0;font-size:14px;line-height:1.6;">Data objectiu: {{ report.target_date }} · Generat: {{ report.generated_at }}</p>
      </td>
    </tr>
    <tr>
      <td style="padding:28px 32px;">

        <h2 style="margin:0 0 12px 0;color:#0f4c81;font-size:22px;line-height:1.3;">Resum executiu</h2>
        <ul style="margin:0 0 24px 18px;padding:0;line-height:1.7;">
          {% for item in report.executive_summary %}
          <li style="margin:0 0 8px 0;">{{ item }}</li>
          {% endfor %}
        </ul>

        <h2 style="margin:0 0 12px 0;color:#0f4c81;font-size:22px;line-height:1.3;">1. Meteorologia</h2>
        <p style="margin:0 0 14px 0;line-height:1.7;">{{ report.weather_summary }}</p>
        <table role="presentation" width="100%" cellspacing="0" cellpadding="0" style="width:100%;border-collapse:collapse;margin:0 0 24px 0;font-size:14px;">
          <tr>
            <th align="left" style="padding:10px;background:#f8fafc;border-bottom:1px solid #d9e2ec;">Franja</th>
            <th align="left" style="padding:10px;background:#f8fafc;border-bottom:1px solid #d9e2ec;">Temperatura</th>
            <th align="left" style="padding:10px;background:#f8fafc;border-bottom:1px solid #d9e2ec;">Pluja</th>
            <th align="left" style="padding:10px;background:#f8fafc;border-bottom:1px solid #d9e2ec;">Vent</th>
          </tr>
          {% for row in report.weather_rows %}
          <tr>
            <td style="padding:10px;border-bottom:1px solid #e5e7eb;vertical-align:top;">{{ row.hour }}</td>
            <td style="padding:10px;border-bottom:1px solid #e5e7eb;vertical-align:top;">{{ row.temp }}{% if row.temp != '-' %} °C{% endif %}</td>
            <td style="padding:10px;border-bottom:1px solid #e5e7eb;vertical-align:top;">{{ row.rain }}{% if row.rain != '-' %} mm{% endif %}</td>
            <td style="padding:10px;border-bottom:1px solid #e5e7eb;vertical-align:top;">{{ row.wind }}</td>
          </tr>
          {% endfor %}
        </table>

        <h2 style="margin:0 0 12px 0;color:#0f4c81;font-size:22px;line-height:1.3;">2. Subministraments</h2>
        <p style="margin:0 0 12px 0;line-height:1.7;"><strong>Electricitat:</strong> {{ report.power_summary }}</p>
        <p style="margin:0 0 24px 0;line-height:1.7;"><strong>Aigua:</strong> {{ report.water_summary }}</p>

        <h2 style="margin:0 0 12px 0;color:#0f4c81;font-size:22px;line-height:1.3;">3. Mobilitat i obres</h2>
        <p style="margin:0 0 24px 0;line-height:1.7;">{{ report.traffic_summary }}</p>

        <h2 style="margin:0 0 12px 0;color:#0f4c81;font-size:22px;line-height:1.3;">4. Activitat cultural i agenda</h2>
        <p style="margin:0 0 14px 0;line-height:1.7;">{{ report.cultural_summary }}</p>
        <table role="presentation" width="100%" cellspacing="0" cellpadding="0" style="width:100%;border-collapse:collapse;margin:0 0 24px 0;font-size:14px;">
          <tr>
            <th align="left" style="padding:10px;background:#f8fafc;border-bottom:1px solid #d9e2ec;">Data</th>
            <th align="left" style="padding:10px;background:#f8fafc;border-bottom:1px solid #d9e2ec;">Activitat</th>
            <th align="left" style="padding:10px;background:#f8fafc;border-bottom:1px solid #d9e2ec;">Lloc</th>
            <th align="left" style="padding:10px;background:#f8fafc;border-bottom:1px solid #d9e2ec;">Categoria</th>
          </tr>
          {% if report.cultural_items %}
            {% for item in report.cultural_items %}
            <tr>
              <td style="padding:10px;border-bottom:1px solid #e5e7eb;vertical-align:top;">{{ item.dates }}</td>
              <td style="padding:10px;border-bottom:1px solid #e5e7eb;vertical-align:top;">
                <strong>{{ item.title }}</strong><br>
                <span style="color:#4b5563;">{{ item.subtitle }}</span><br>
                <a href="{{ item.url }}" target="_blank" rel="noopener noreferrer" style="color:#0f4c81;text-decoration:none;">Veure fitxa</a>
              </td>
              <td style="padding:10px;border-bottom:1px solid #e5e7eb;vertical-align:top;">{{ item.venue }}</td>
              <td style="padding:10px;border-bottom:1px solid #e5e7eb;vertical-align:top;">{{ item.category }}</td>
            </tr>
            {% endfor %}
          {% else %}
            <tr>
              <td colspan="4" style="padding:10px;border-bottom:1px solid #e5e7eb;vertical-align:top;">No s'han pogut extreure activitats culturals estructurades en aquesta execució.</td>
            </tr>
          {% endif %}
        </table>

        <h2 style="margin:0 0 12px 0;color:#0f4c81;font-size:22px;line-height:1.3;">5. Validacions</h2>
        <table role="presentation" width="100%" cellspacing="0" cellpadding="0" style="width:100%;border-collapse:collapse;margin:0 0 24px 0;font-size:14px;">
          <tr>
            <th align="left" style="padding:10px;background:#f8fafc;border-bottom:1px solid #d9e2ec;">Resultat</th>
          </tr>
          {% for item in report.validations %}
          <tr>
            <td style="padding:10px;border-bottom:1px solid #e5e7eb;vertical-align:top;{% if item.startswith('ERROR') %}color:#991b1b;{% elif item.startswith('OK') %}color:#166534;{% endif %}">{{ item }}</td>
          </tr>
          {% endfor %}
        </table>

        <h2 style="margin:0 0 12px 0;color:#0f4c81;font-size:22px;line-height:1.3;">6. Avisos tècnics</h2>
        <table role="presentation" width="100%" cellspacing="0" cellpadding="0" style="width:100%;border-collapse:collapse;margin:0 0 24px 0;font-size:14px;">
          <tr>
            <th align="left" style="padding:10px;background:#fff7ed;border-bottom:1px solid #fed7aa;color:#9a3412;">Avisos</th>
          </tr>
          {% if report.warnings %}
            {% for item in report.warnings %}
            <tr>
              <td style="padding:10px;border-bottom:1px solid #ffedd5;vertical-align:top;color:#9a3412;">{{ item }}</td>
            </tr>
            {% endfor %}
          {% else %}
            <tr>
              <td style="padding:10px;border-bottom:1px solid #e5e7eb;vertical-align:top;color:#166534;">Sense avisos tècnics.</td>
            </tr>
          {% endif %}
        </table>

        <h2 style="margin:0 0 12px 0;color:#0f4c81;font-size:22px;line-height:1.3;">7. Metodologia</h2>
        <ul style="margin:0 0 24px 18px;padding:0;line-height:1.7;">
          {% for item in report.methodology %}
          <li style="margin:0 0 8px 0;">{{ item }}</li>
          {% endfor %}
        </ul>

        <h2 style="margin:0 0 12px 0;color:#0f4c81;font-size:22px;line-height:1.3;">8. Fonts oficials consultades</h2>
        <ul style="margin:0 0 0 18px;padding:0;line-height:1.7;">
          {% for name, url in report.sources %}
          <li style="margin:0 0 8px 0;"><a href="{{ url }}" target="_blank" rel="noopener noreferrer" style="color:#0f4c81;text-decoration:none;">{{ name }}</a></li>
          {% endfor %}
        </ul>

      </td>
    </tr>
  </table>
</body>
</html>
