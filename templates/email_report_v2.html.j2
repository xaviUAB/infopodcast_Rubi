<!doctype html>
<html lang="ca">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>Informe diari de Rubí v2</title>
</head>
<body style="margin:0;padding:24px;background:#eef2f7;font-family:Arial,Helvetica,sans-serif;color:#1f2937;">
<table role="presentation" width="100%" cellspacing="0" cellpadding="0" style="max-width:980px;margin:0 auto;background:#ffffff;border:1px solid #d9e2ec;border-radius:12px;overflow:hidden;">
<tr><td style="padding:28px 32px;background:#0f4c81;color:#ffffff;">
<h1 style="margin:0 0 8px 0;font-size:28px;">Informe diari de Rubí · versió 2</h1>
<p style="margin:0;font-size:14px;line-height:1.6;">Data objectiu: {{ report.target_date }} · Generat: {{ report.generated_at }}</p>
</td></tr>
<tr><td style="padding:28px 32px;">
<h2 style="margin:0 0 12px 0;color:#0f4c81;font-size:22px;">Resum executiu</h2>
<ul style="margin:0 0 24px 18px;line-height:1.7;">{% for item in report.executive_summary %}<li>{{ item }}</li>{% endfor %}</ul>

<h2 style="margin:0 0 12px 0;color:#0f4c81;font-size:22px;">1. Meteorologia</h2>
<p style="line-height:1.7;margin:0 0 14px 0;">{{ report.weather_summary }}</p>
<table role="presentation" width="100%" cellspacing="0" cellpadding="0" style="border-collapse:collapse;margin:0 0 24px 0;font-size:14px;">
<tr><th align="left" style="padding:10px;background:#f8fafc;border-bottom:1px solid #d9e2ec;">Hora</th><th align="left" style="padding:10px;background:#f8fafc;border-bottom:1px solid #d9e2ec;">Temperatura</th><th align="left" style="padding:10px;background:#f8fafc;border-bottom:1px solid #d9e2ec;">Pluja</th><th align="left" style="padding:10px;background:#f8fafc;border-bottom:1px solid #d9e2ec;">Vent</th></tr>
{% for row in report.weather_rows %}<tr><td style="padding:10px;border-bottom:1px solid #e5e7eb;">{{ row.hour }}</td><td style="padding:10px;border-bottom:1px solid #e5e7eb;">{{ row.temp }}{% if row.temp != '-' %} °C{% endif %}</td><td style="padding:10px;border-bottom:1px solid #e5e7eb;">{{ row.rain }}{% if row.rain != '-' %} mm{% endif %}</td><td style="padding:10px;border-bottom:1px solid #e5e7eb;">{{ row.wind }}</td></tr>{% endfor %}
</table>

<h2 style="margin:0 0 12px 0;color:#0f4c81;font-size:22px;">2. Subministraments</h2>
<p style="margin:0 0 12px 0;line-height:1.7;"><strong>Electricitat:</strong> {{ report.power_summary }}</p>
<p style="margin:0 0 24px 0;line-height:1.7;"><strong>Aigua:</strong> {{ report.water_summary }}</p>

<h2 style="margin:0 0 12px 0;color:#0f4c81;font-size:22px;">3. Mobilitat i obres</h2>
<p style="margin:0 0 24px 0;line-height:1.7;">{{ report.traffic_summary }}</p>

<h2 style="margin:0 0 12px 0;color:#0f4c81;font-size:22px;">4. Activitat cultural i agenda</h2>
<p style="margin:0 0 14px 0;line-height:1.7;">{{ report.cultural_summary }}</p>
<table role="presentation" width="100%" cellspacing="0" cellpadding="0" style="border-collapse:collapse;margin:0 0 24px 0;font-size:14px;">
<tr><th align="left" style="padding:10px;background:#f8fafc;border-bottom:1px solid #d9e2ec;">Data</th><th align="left" style="padding:10px;background:#f8fafc;border-bottom:1px solid #d9e2ec;">Activitat</th><th align="left" style="padding:10px;background:#f8fafc;border-bottom:1px solid #d9e2ec;">Lloc</th><th align="left" style="padding:10px;background:#f8fafc;border-bottom:1px solid #d9e2ec;">Categoria</th></tr>
{% for item in report.cultural_items %}<tr><td style="padding:10px;border-bottom:1px solid #e5e7eb;vertical-align:top;">{{ item.dates }}</td><td style="padding:10px;border-bottom:1px solid #e5e7eb;vertical-align:top;"><strong>{{ item.title }}</strong><br><span style="color:#4b5563;">{{ item.subtitle }}</span><br><a href="{{ item.url }}" target="_blank" rel="noopener noreferrer" style="color:#0f4c81;text-decoration:none;">Veure fitxa</a></td><td style="padding:10px;border-bottom:1px solid #e5e7eb;vertical-align:top;">{{ item.venue }}</td><td style="padding:10px;border-bottom:1px solid #e5e7eb;vertical-align:top;">{{ item.category }}</td></tr>{% endfor %}
</table>

<h2 style="margin:0 0 12px 0;color:#0f4c81;font-size:22px;">5. Metodologia i cauteles</h2>
<ul style="margin:0 0 24px 18px;line-height:1.7;">{% for item in report.methodology %}<li>{{ item }}</li>{% endfor %}</ul>

<h2 style="margin:0 0 12px 0;color:#0f4c81;font-size:22px;">Fonts oficials consultades</h2>
<ul style="margin:0 0 0 18px;line-height:1.7;">{% for name, url in report.sources %}<li><a href="{{ url }}" target="_blank" rel="noopener noreferrer">{{ name }}</a></li>{% endfor %}</ul>
</td></tr>
</table>
</body>
</html>
